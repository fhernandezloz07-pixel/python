# Problem 5: Max Difference
    # Write a function max_difference() 
    # that takes in a list of integers lst 
    # and returns the difference 
    # between the smallest and largest value in the list.
def max_difference(lst):
    if lst == []: # Add == because we are determining if this is true or not
        return None # Accounts for empty list
    
    # Step 1: Find Max
    max_num = lst[0] # initialize at the first number in the list; call list then at what index you want it
    for num in lst: # for every number in the list run a loop that checks if tha number is greater than num_lst. Runs for each number 
        if num > max_num:
            max_num = num # replace if there is a number actually greater than the previous number in the list, runs throuhg entire list
    # findind the min is the same steps basically!
    # Step 2: find min 
    min_num = lst[0]
    for num in lst:
        if num < min_num:
            min_num = num 

    # Step 3: Compute the difference
    max_diff = max_num - min_num
    return max_diff

lst = [5,22,8,10,2]
max_diff = max_difference(lst)
print(max_diff)
# What did you learn? 
    # if I have to test multiple things at a time go step by stem 
        # find the max first, then find the min and run the loop for each number
    # I also found out that I have to do returns on everything even if it's not a loop! 
        # for example max_diff variable 

