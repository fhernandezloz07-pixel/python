    # Hint: This is a lists problem
'''
U:
Check if a given list nums is monotone increasing or monotone dectreasing
monotone increasing if all the elements in the list is greater than or equal to the element before it (Return True)
A list is monotone decreasing if every element is less than or equal to the element before it (Return True)
If neither return false. 

P:
Define a function with adequate parameters
for every element in a given list 
run an if loop to check the conditions

Note: Do I have to kae use of len(nums) to know what index somethign is in?
'''
# I:
def is_monotonic(nums):
    increasing = True # make the conditions of increasing montonic and decreasing monotonic true
    decreasing = True

    for i in range(1, len(nums)): # for an element in the range 1 to the very last number in the list... we are checking the second value compared to the first value 
        if nums[i] < nums[i-1]: # if the index of the element in the list is greater than the 
            increasing = False 
        if nums[i] > nums[i-1]:
            decreasing = False

    return increasing or decreasing # if either one can be possible return true, if neither is possible like the loop retunrn true

