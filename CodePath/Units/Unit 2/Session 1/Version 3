def average_book_ratings(book_ratings):
    new_dictionary = {}
    for i in book_ratings:
        list_addition = 0
        for j in book_ratings[i]:
            list_addition += j
        average_rating = list_addition / len(book_ratings[i])
        new_dictionary[i]= average_rating
    return new_dictionary

