7. return attendance_percentage
'''
# I: 
def attendance_rate(attendance_list):
    key_count = 0 # checks how many keys there are
    present_count = 0 # checks how many presents' there are 
    for item in attendance_list:
        key_count += 1
        if attendance_list[item] == "Present":
            present_count += 1
    fraction = present_count / key_count
    attendance_percentage = fraction * 100
    return attendance_percentage

