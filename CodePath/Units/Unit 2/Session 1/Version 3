'''
U:
There are 2 lists, one with the names of the products and another with their prices
I have to pair each name with the corresponding price 
assuming we are going in order of the indexes of both lists!

P:
1. define a fucntion with appropiate parameters
2. initialize an empty dicitonary where we will store the keys and values needed
3. i in range(len(product_names)) -> for every index of the list of names
4. call the dictionary and the keys and make it equal to values 

Note: Same thing we already did, you cant use range len in the for loop 
for a dictionary but you can use other things!
'''
def build_inventory(product_names, product_prices):
    inventory_dictionary = {}
    for i in range(len(product_names)):
        inventory_dictionary[product_names[i]] = product_prices[i] 
# This is very important, if i dont include product_names iside the calling 
# then it will print out the number of the indez not the actual name!
    return inventory_dictionary
product_names = ["Apple", "Banana", "Orange"]
product_prices = [0.99, 0.50, 0.75]
print(build_inventory(product_names, product_prices))
