# Example Code:
def find_peak(lst):
    for i in range(1, len(lst)-1):
        if lst[i] > lst[i-1] and lst[i] > lst[i + 1]:
            return i
lst = [1,3,5,9,7,4,2]
print(find_peak(lst))
