def keys_v_values(dictionary):
    sum_keys = 0
    sum_values = 0
    for i in dictionary:
        sum_keys += i
        sum_values += dictionary[i]

    if sum_keys > sum_values:
        return "keys"
    if sum_values > sum_keys:
        return "values"
